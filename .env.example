# ===================================================
# Jellywatch — Backend Environment Variables
# ===================================================
# Copy this file to .env and fill in your values.
# The backend reads this file on startup.
# In CasaOS/Docker, set these as container env vars instead.
# ===================================================

# --------------------------------------------------
# 1. JELLYFIN CONNECTION (REQUIRED)
# --------------------------------------------------
# Your Jellyfin server URL (no trailing slash)
JELLYFIN_BASE_URL=http://localhost:8096

# Jellyfin API key — generate one in Jellyfin:
#   Dashboard → API Keys → Add (name it "Jellywatch")
JELLYFIN_API_KEY=

# Optional: secret for Jellyfin webhook plugin (real-time sync)
JELLYFIN_WEBHOOK_SECRET=

# --------------------------------------------------
# 2. METADATA PROVIDERS (OPTIONAL but recommended)
# --------------------------------------------------
# TMDB — get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb — get your key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# --------------------------------------------------
# 3. JWT AUTHENTICATION
# --------------------------------------------------
# Secret key for signing JWT tokens (min 32 characters)
JWT_SECRET_KEY=YourSecretKeyHere-MustBeAtLeast32Characters!
JWT_ISSUER=Jellywatch.Api
JWT_AUDIENCE=Jellywatch.Client
JWT_EXPIRATION_MINUTES=10080

# --------------------------------------------------
# 4. DATABASE
# --------------------------------------------------
DATABASE_PATH=../jellywatch.db
